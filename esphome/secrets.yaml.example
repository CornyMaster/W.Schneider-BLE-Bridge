# =============================================================================
# ESPHome secrets — TEMPLATE
# Copy to secrets.yaml (same directory as mirror-cabinet.yaml) and fill in
# your values. secrets.yaml is gitignored and must never be committed.
# =============================================================================

# --- Wi-Fi network the ESP32 should join ---------------------------------------
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# --- Home Assistant native API encryption (generate: openssl rand -base64 32) --
api_encryption_key: "PUT_A_32_BYTE_BASE64_KEY_HERE"

# --- Password for over-the-air firmware updates --------------------------------
ota_password: "PUT_AN_OTA_PASSWORD_HERE"

# --- Password of the fallback setup hotspot the ESP opens when Wi-Fi fails -----
fallback_ap_password: "PUT_A_FALLBACK_AP_PASSWORD_HERE"
